---
import { link } from '../consts';
const today = new Date();
---

<footer>
<div class="footer-inner">
<div class="footer-brand">
<span class="footer-logo">✦ Foiga Photography</span>
<p class="footer-tagline">Capturing moments that last forever.</p>
</div>
<div class="footer-links">
<a href={link('/#portfolio')}>Portfolio</a>
<a href={link('/#about')}>About</a>
<a href={link('/#contact')}>Contact</a>
<a href={link('/uno')}>UNO</a>
<a href={link('/baseball')}>野球</a>
<a href={link('/race')}>レース</a>
</div>
</div>
<div class="footer-bottom">
<p>&copy; {today.getFullYear()} Foiga Photography. All rights reserved.</p>
</div>
</footer>

<style>
footer {
background-color: #0a0a0a;
border-top: 1px solid rgba(201, 168, 76, 0.2);
padding: 3rem 0 0;
}

.footer-inner {
max-width: 1200px;
margin: 0 auto;
padding: 0 2rem 3rem;
display: flex;
justify-content: space-between;
align-items: flex-start;
gap: 2rem;
flex-wrap: wrap;
}

.footer-logo {
font-size: 1.1rem;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 0.1em;
color: #c9a84c;
}

.footer-tagline {
margin: 0.5rem 0 0;
color: rgba(160, 160, 160, 0.7);
font-size: 0.9rem;
}

.footer-links {
display: flex;
gap: 1.5rem;
align-items: center;
flex-wrap: wrap;
}

.footer-links a {
color: rgba(220, 220, 220, 0.7);
text-decoration: none;
font-size: 0.875rem;
text-transform: uppercase;
letter-spacing: 0.08em;
transition: color 0.3s ease;
}

.footer-links a:hover {
color: #c9a84c;
}

.footer-bottom {
border-top: 1px solid rgba(255, 255, 255, 0.05);
padding: 1.25rem 2rem;
text-align: center;
}

.footer-bottom p {
margin: 0;
color: rgba(160, 160, 160, 0.5);
font-size: 0.8rem;
}
</style>
